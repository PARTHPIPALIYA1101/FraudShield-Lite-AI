# ============================================================================
# FraudShield Lite AI — Backend Environment
# ----------------------------------------------------------------------------
# Loaded by backend/config.py (pydantic-settings). When the backend runs on the
# HOST during dev, services are reached at localhost on their published ports.
# (If you later containerize the backend, swap localhost -> service names:
#  postgres / redis / kafka:29092.)
# ============================================================================

# --- PostgreSQL ---------------------------------------------------------------
# asyncpg driver for the app (async SQLAlchemy engine).
DATABASE_URL=postgresql+asyncpg://fraud:fraud@localhost:5432/fraudshield
# psycopg2 driver for sync tooling (Alembic migrations, scripts).
SYNC_DATABASE_URL=postgresql://fraud:fraud@localhost:5432/fraudshield

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Kafka --------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- LLM provider -------------------------------------------------------------
# "gemini" (Google AI Studio, free) or "anthropic" (Claude SDK).
LLM_PROVIDER=gemini

# --- Google AI Studio / Gemini ------------------------------------------------
# Get a FREE key at https://aistudio.google.com/apikey and paste it below.
GOOGLE_API_KEY="GOOGLE_API_KEY"
# gemini-2.0-flash has free-tier limit 0 for this project; 2.5-flash-lite has quota.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic / Claude (alternate provider; Aerolink proxy is CLI-only) ------
# Kept for drop-in swap. The Aerolink proxy only serves Claude Code CLI, so
# direct SDK calls return "Please use Claude Code CLI". Use a real sk-ant- key
# with ANTHROPIC_BASE_URL=https://api.anthropic.com to enable this provider.
ANTHROPIC_API_KEY="ANTHROPIC_API_KEY"
ANTHROPIC_BASE_URL=https://api.anthropic.com/
ANTHROPIC_MODEL=claude-opus-4-8

# --- Postgres container bootstrap (mirrors docker-compose defaults) -----------
POSTGRES_DB=fraudshield
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
