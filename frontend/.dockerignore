# Keep host build artifacts out of the image. In particular, host node_modules
# are Windows binaries and would clobber the Linux ones from `npm install`.
# NOTE: .env.local is intentionally NOT ignored — NEXT_PUBLIC_* vars are inlined
# at build time, so the /api URLs must be present during `npm run build`.
node_modules
.next
out
build
npm-debug.log*
.git
Dockerfile
.dockerignore
*.tsbuildinfo
